            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relevantForRoles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "VendorReviewItem": {
        "type": "object",
