            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "SuggestionRequest": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          }
        }
      },
      "SuggestionResponse": {
        "type": "object",
        "properties": {
