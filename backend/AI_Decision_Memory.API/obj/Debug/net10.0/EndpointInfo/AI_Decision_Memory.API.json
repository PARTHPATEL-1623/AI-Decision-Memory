            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ContradictionPair": {
        "type": "object",
        "properties": {
          "newerDecision": {
            "$ref": "#/components/schemas/Decision"
          },
          "olderDecision": {
            "$ref": "#/components/schemas/Decision"
          },
          "isResolved": {
            "type": "boolean"
          }
        }
      },
      "Decision": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "dateDecided": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string"
          },
          "alternativesConsidered": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Alternative"
            }
          },
          "stakeholders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stakeholder"
            }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "contradictedBy": {
            "type": [
              "null",
              "string"
            ]
          },
          "relevantForRoles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "vendorCost": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "null",
              "number",
              "string"
            ],
            "format": "double"
          },
          "contractRenewalDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "linkedEntities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkedEntity"
            }
          },
          "lifecycleEvents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LifecycleEvent"
            }
          }
        }
      },
      "DecisionAIResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "string"
          },
          "reasoning": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "stakeholders": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dateDecided": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            }
