          "matchedDecisionId": {
            "type": [
              "null",
              "string"
            ]
          },
          "isSuccess": {
            "type": "boolean"
          }
        }
      },
      "DepartmentHealthReport": {
        "type": "object",
        "properties": {
          "overallComplianceScore": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "totalDecisionsCatalogued": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "departmentScorecards": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepartmentScorecard"
            }
          }
        }
      },
      "DepartmentScorecard": {
        "type": "object",
        "properties": {
          "departmentName": {
            "type": "string"
          },
          "decisionsCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "fullReasoningPercentage": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "contradictionCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "avgTimeToAnswerMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "healthStatus": {
            "type": "string"
          }
        }
      },
      "LifecycleEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "LinkedEntity": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
